with "../../database.gpr";
project Persistent is
   for Source_Dirs use ("src");
   for Main use ("main.adb");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa", "-gnatW8");
   end Compiler;
end Persistent;
