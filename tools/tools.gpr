with "../../project_tools/project_tools.gpr";

project Tools is
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("check_all.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2022", "-gnatyM120", "-gnatX", "-gnata");
   end Compiler;
end Tools;
